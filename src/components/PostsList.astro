---
import DatePresenter from '@/components/DatePresenter.astro'
import TagsPresenter from '@/components/TagsPresenter.astro'
import type { NormalizedPost } from '@/lib/strapi'
import { getMediaUrl } from '@/lib/strapi'
import type { Page } from 'astro'

const {
  page,
  posts,
  tag = null,
  category = null,
  total = null,
} = Astro.props as {
  page: Page<NormalizedPost>
  posts: NormalizedPost[]
  tag: string | null
  category: string | null
  total: number | null
}
---

<section
  class="mx-auto max-w-3xl w-full mt-40 px-4 xl:px-0 mb-20"
>
  {tag && (
    <h2 class="text-4xl font-bold mb-6">Tag: {tag} ({total})</h2>
  )}
  {category && (
    <h2 class="text-4xl font-bold mb-6">Category: {category} ({total})</h2>
  )}
  <div class="posts divide-y divide:gray-400">
    {
      posts.map(post => (
        <div class="post py-8">
          {post.featuredImage && (
            <a href={`/articles/${post.slug}`}>
              <img
                src={getMediaUrl(post.featuredImage.formats?.medium?.url ?? post.featuredImage.url)}
                alt={post.featuredImage.alternativeText ?? post.title}
                class="w-full h-56 object-cover rounded-lg mb-5"
                transition:name={`featured-image-${post.slug}`}
              />
            </a>
          )}
          <div class="flex items-center gap-3">
            <DatePresenter
              date={post.date}
              transitionName={post.date.toString()}
            />
            {post.category && (
              <a
                href={`/categories/${post.category.slug}`}
                class="text-xs font-semibold uppercase tracking-wide bg-blue-700 text-white rounded-md px-3 py-1 hover:bg-blue-600 transition-colors"
              >
                {post.category.title}
              </a>
            )}
          </div>
          <h2 class="text-3xl font-bold mt-1" transition:name={post.title}>
            <a
              href={`/articles/${post.slug}`}
              class="hover:text-gray-500"
            >
              {post.title}
            </a>
          </h2>

          {post.tags.length > 0 && <TagsPresenter tags={post.tags} />}

          {post.summary && (
            <div class="line-clamp-3 text-gray-600 mt-4">
              {post.summary}
            </div>
          )}
          <div class="mt-4">
            <a
              href={`/articles/${post.slug}`}
              class="font-bold uppercase hover:text-gray-500"
            >
              Read More
            </a>
          </div>
        </div>
      ))
    }
  </div>
  {
    page.lastPage !== 1 && (
      <div class="pagination flex justify-between text-base items-center border-t border-gray-200 pt-8">
        {page.url.prev ? (
          <a
            href={page.url.prev}
            class="hover:text-gray-500"
          >
            &larr; Prev
          </a>
        ) : (
          <button class="disabled:opacity-50" disabled>
            &larr; Prev
          </button>
        )}
        <div>
          Page {page.currentPage} of {page.lastPage}
        </div>
        {page.url.next ? (
          <a
            href={page.url.next}
            class="hover:text-gray-500"
          >
            Next &rarr;
          </a>
        ) : (
          <button class="disabled:opacity-50" disabled>
            Next &rarr;
          </button>
        )}
      </div>
    )
  }
</section>
