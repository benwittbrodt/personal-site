---
const { tags } = Astro.props as {
  tags: Array<string>
}
---

<ul
  class="flex items-center text-blue-600 dark:text-blue-300 flex-wrap text-base gap-x-4 mt-1"
>
  {
    tags.map(tag => (
      <li>
        <a
          href={`/tags/${tag}`}
          class="hover:text-blue-400 dark:hover:text-blue-200"
        >
          {tag}
        </a>
      </li>
    ))
  }
</ul>
