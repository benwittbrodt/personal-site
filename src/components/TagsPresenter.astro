---
const { tags } = Astro.props as {
  tags: Array<{ title: string; slug: string }>
}
---

<div class="flex items-center flex-wrap gap-2 mt-2">
  {tags.map(tag => (
    <a
      href={`/tags/${tag.slug}`}
      class="text-xs font-medium bg-gray-100 text-gray-600 rounded-full px-3 py-1 hover:bg-gray-200 transition-colors"
    >
      {tag.title}
    </a>
  ))}
</div>
