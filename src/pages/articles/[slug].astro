---
import Layout from '@/layouts/Layout.astro'
import DatePresenter from '@/components/DatePresenter.astro'
import TagsPresenter from '@/components/TagsPresenter.astro'
import { getPosts, getMediaUrl } from '@/lib/strapi'
import { normalizePost } from '@/lib/strapi-blocks'

export async function getStaticPaths() {
  const posts = (await getPosts()).map(normalizePost)
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }))
}

const { post } = Astro.props
---

<Layout title={post.title}>
  <section
    class="mx-auto max-w-3xl mt-40 px-4 xl:px-0 mb-20"
  >
    <div class="post py-8">
      {post.featuredImage && (
        <img
          src={getMediaUrl(post.featuredImage.formats?.large?.url ?? post.featuredImage.url)}
          alt={post.featuredImage.alternativeText ?? post.title}
          class="w-full h-72 object-cover rounded-xl mb-8"
          transition:name={`featured-image-${post.slug}`}
        />
      )}
      <div class="flex items-center gap-3">
        <DatePresenter
          date={post.date}
          transitionName={post.date.toString()}
        />
        {post.category && (
          <a
            href={`/categories/${post.category.slug}`}
            class="text-xs font-semibold uppercase tracking-wide bg-blue-700 text-white rounded-md px-3 py-1 hover:bg-blue-600 transition-colors"
          >
            {post.category.title}
          </a>
        )}
      </div>
      <h2 class="text-4xl font-bold mt-1" transition:name={post.title}>
        {post.title}
      </h2>
      {post.tags.length > 0 && <TagsPresenter tags={post.tags} />}
      <div
        class="prose prose-lg max-w-none text-gray-600 mt-8"
        set:html={post.contentHtml}
      />
      <div class="pt-8 mt-8 border-t border-gray-300">
        <a
          href="/articles"
          class="font-bold uppercase hover:text-gray-500"
        >
          Back to Articles
        </a>
      </div>
    </div>
  </section>
</Layout>
