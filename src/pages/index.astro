---
import Layout from '@/layouts/Layout.astro'
import { Image } from 'astro:assets'
import headshot from '@/images/headshot.jpg'
import { getPosts, getMediaUrl } from '@/lib/strapi'
import { normalizePost } from '@/lib/strapi-blocks'
import DatePresenter from '@/components/DatePresenter.astro'

const allPosts = (await getPosts()).map(normalizePost)
const recentPosts = allPosts.slice(0, 3)

const topics = [
  {
    title: 'Personal Finance',
    description: 'Practical takes on budgeting, investing, and building wealth on your own terms.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>`,
  },
  {
    title: 'Watches',
    description: 'Thoughts on horology, collecting, and the watches worth your time and money.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>`,
  },
  {
    title: 'Home Automation',
    description: 'Smart home setups, self-hosted tools, and making your home actually work for you.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>`,
  },
]
---

<Layout title="Home" showNewsletter={false}>
  <main>

    <!-- Hero -->
    <section class="mx-auto max-w-3xl px-4 xl:px-0 pt-36 pb-20 flex flex-col sm:flex-row items-center gap-10">
      <Image
        src={headshot}
        alt="Ben Wittbrodt"
        class="w-56 h-56 rounded-2xl object-cover shadow-md shrink-0"
      />
      <div>
        <h1 class="text-4xl font-bold dark:text-gray-100">
          Hey, I'm <span class="text-blue-700 dark:text-blue-400">Ben Wittbrodt</span>
        </h1>
        <p class="mt-3 text-gray-600 dark:text-gray-300 text-lg leading-relaxed">
          I write about personal finance, watches, and home automation — the things I spend too much time thinking about.
        </p>
        <div class="flex gap-3 mt-6">
          <a
            href="/articles"
            class="rounded-lg bg-blue-700 hover:bg-blue-600 text-white text-sm font-medium px-5 py-2.5 transition-colors"
          >
            Read articles
          </a>
          <a
            href="/contact"
            class="rounded-lg border border-gray-300 dark:border-gray-600 hover:border-blue-700 dark:hover:border-blue-400 text-gray-700 dark:text-gray-300 text-sm font-medium px-5 py-2.5 transition-colors"
          >
            Get in touch
          </a>
        </div>
      </div>
    </section>

    <!-- Topics -->
    <section class="bg-gray-50 dark:bg-slate-800 py-16 px-4 xl:px-0 hidden">
      <div class="mx-auto max-w-3xl">
        <h2 class="text-2xl font-bold dark:text-gray-100 mb-8">What I write about</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          {topics.map(topic => (
            <div class="bg-white dark:bg-slate-700 rounded-xl p-6 shadow-sm">
              <div class="text-blue-700 dark:text-blue-400 mb-3" set:html={topic.icon} />
              <h3 class="font-semibold dark:text-gray-100 mb-1">{topic.title}</h3>
              <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed">{topic.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Recent Articles -->
    <section class="mx-auto max-w-3xl px-4 xl:px-0 py-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold dark:text-gray-100">Recent articles</h2>
        <a href="/articles" class="text-sm text-blue-700 dark:text-blue-400 hover:underline font-medium">
          View all &rarr;
        </a>
      </div>

      {recentPosts.length === 0 ? (
        <p class="text-gray-500 dark:text-gray-400">No articles yet — check back soon.</p>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          {recentPosts.map(post => (
            <a href={`/articles/${post.slug}`} class="group flex flex-col rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden hover:border-blue-700 dark:hover:border-blue-400 transition-colors">
              {post.featuredImage ? (
                <img
                  src={getMediaUrl(post.featuredImage.formats?.medium?.url ?? post.featuredImage.url)}
                  alt={post.featuredImage.alternativeText ?? post.title}
                  class="w-full h-40 object-cover"
                  transition:name={`featured-image-${post.slug}`}
                />
              ) : (
                <div class="w-full h-40 bg-gray-100 dark:bg-slate-700" />
              )}
              <div class="p-4 flex flex-col flex-1">
                <p class="text-xs text-gray-400 dark:text-gray-500 mb-1">
                  <DatePresenter date={post.date} transitionName={post.date.toString()} />
                </p>
                <h3 class="font-semibold dark:text-gray-100 group-hover:text-blue-700 dark:group-hover:text-blue-400 transition-colors leading-snug">
                  {post.title}
                </h3>
                {post.summary && (
                  <p class="text-sm text-gray-500 dark:text-gray-400 mt-2 line-clamp-2 flex-1">
                    {post.summary}
                  </p>
                )}
              </div>
            </a>
          ))}
        </div>
      )}
    </section>

  </main>
</Layout>
