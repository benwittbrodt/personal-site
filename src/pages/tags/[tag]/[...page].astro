---
import Layout from '@/layouts/Layout.astro'
import PostsList from '@/components/PostsList.astro'
import { getPosts } from '@/lib/strapi'
import { normalizePost } from '@/lib/strapi-blocks'
import { sortPostsByDateDesc } from '@/utils/post-utils'
import type { GetStaticPathsOptions } from 'astro'

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = (await getPosts()).map(normalizePost).sort(sortPostsByDateDesc)

  const tagMap = new Map<string, string>()
  for (const post of posts) {
    for (const tag of post.tags) {
      tagMap.set(tag.slug, tag.title)
    }
  }

  return [...tagMap.entries()].flatMap(([slug, title]) => {
    const tagPosts = posts.filter(post => post.tags.some(t => t.slug === slug))
    return paginate(tagPosts, {
      pageSize: 10,
      params: { tag: slug },
      props: { tag: title },
    })
  })
}

const { tag, page } = Astro.props
---

<Layout title={`Tag: ${tag}`}>
  <PostsList page={page} posts={page.data} tag={tag} total={page.total} />
</Layout>
