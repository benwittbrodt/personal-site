---
import Layout from '@/layouts/Layout.astro'
import { getBackground, getMediaUrl } from '@/lib/strapi'
import { blocksToHtml } from '@/lib/strapi-blocks'

const background = await getBackground()
const summaryHtml = blocksToHtml(background.ProfessionalSummary)

function formatDate(dateStr: string | null): string {
  if (!dateStr) return 'Present'
  const date = new Date(dateStr)
  return date.toLocaleDateString('en-US', { month: 'long', year: 'numeric', timeZone: 'utc' })
}

function dateRange(start: string, end: string | null): string {
  return `${formatDate(start)} – ${formatDate(end)}`
}
---

<Layout title="Background">
  <section class="mx-auto max-w-5xl dark:text-gray-100 mt-40 px-4 xl:px-0 mb-20">
    <h2 class="text-4xl font-bold mb-10">
      My <span class="text-blue-700 dark:text-blue-400">Background</span>
    </h2>

    <div
      class="prose dark:prose-invert prose-lg max-w-none text-gray-600 dark:text-gray-300 mb-10"
      set:html={summaryHtml}
    />

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Experience column -->
      <div class="lg:col-span-2 space-y-6">
        <h3 class="text-xl font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-4">
          Professional Experience
        </h3>

        {background.Experience.map(exp => (
          <div class="border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden">
            <!-- Company logo -->
            {exp.CompanyLogo && (
              <div class="flex justify-center items-center px-6 py-5 border-b border-gray-100 dark:border-gray-700 bg-white dark:bg-gray-800">
                <img
                  src={getMediaUrl(exp.CompanyLogo.formats?.small?.url ?? exp.CompanyLogo.url)}
                  alt={exp.Company}
                  class="max-h-14 max-w-xs object-contain"
                />
              </div>
            )}

            <!-- Roles -->
            <div class="divide-y divide-gray-100 dark:divide-gray-700">
              {exp.Role.map((role, i) => (
                <div class={`px-6 py-5 ${i % 2 === 0 ? 'bg-white dark:bg-gray-900' : 'bg-gray-50 dark:bg-gray-800/60'}`}>
                  <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 mb-3">
                    <h4 class="text-lg font-semibold">{role.JobTitle}</h4>
                    <span class="text-sm text-gray-500 dark:text-gray-400 whitespace-nowrap">
                      {dateRange(role.StartDate, role.EndDate)}
                    </span>
                  </div>
                  <div
                    class="prose prose-sm dark:prose-invert max-w-none text-gray-600 dark:text-gray-300"
                    set:html={blocksToHtml(role.JobDescription)}
                  />
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Education column -->
      <div class="space-y-6">
        <h3 class="text-xl font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-4">
          Education
        </h3>

        <div class="border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden">
          <div class="flex justify-center items-center px-6 py-5 border-b border-gray-100 dark:border-gray-700 bg-white dark:bg-gray-800">
            <img
              src="https://upload.wikimedia.org/wikipedia/commons/thumb/1/14/Michigan_tech_univ_husky_logo.png/500px-Michigan_tech_univ_husky_logo.png"
              alt="Michigan Tech"
              class="max-h-14 object-contain"
            />
          </div>
          <div class="px-6 py-5 bg-white dark:bg-gray-900 border-b border-gray-100 dark:border-gray-700">
            <div class="flex flex-col gap-1 mb-3">
              <h4 class="text-base font-semibold">M.S. Material Science &amp; Engineering</h4>
              <span class="text-sm text-gray-500 dark:text-gray-400">December 2014</span>
            </div>
            <p class="text-sm text-gray-600 dark:text-gray-300">Michigan Technological University</p>
          </div>
          <div class="px-6 py-5 bg-gray-50 dark:bg-gray-800/60">
            <div class="flex flex-col gap-1 mb-3">
              <h4 class="text-base font-semibold">B.S. Material Science &amp; Engineering</h4>
              <span class="text-sm text-gray-500 dark:text-gray-400">May 2013</span>
            </div>
            <p class="text-sm text-gray-600 dark:text-gray-300">Michigan Technological University</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
